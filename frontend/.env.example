# Smart Queue System - Frontend Environment Configuration

# API Backend URL (Render deployment)
# For production: https://your-render-url.onrender.com
# For local development: Leave empty to use Vite proxy (http://localhost:8080)
# Note: The API client will automatically append /api to this URL
VITE_API_URL=https://smart-queue-system-1.onrender.com

# Optional: Enable API request/response logging in console
VITE_DEBUG_API=false

# Optional: API request timeout in milliseconds
VITE_API_TIMEOUT=10000
